  </nav>

</div>
<script>
document.addEventListener('DOMContentLoaded', function () {
  var $ = function (id) { return document.getElementById(id); };

  /* ── API proxy base (keys live server-side, see /server/README.md).
     Default: same host as the page on port 8787 (the local proxy). Override
     once with localStorage.setItem('carbox.apiBase','https://your-deploy'). ── */
  var API_BASE = (function () {
    try { var s = localStorage.getItem('carbox.apiBase'); if (s) return s.replace(/\/+$/, ''); } catch (e) {}
    if (location.protocol === 'http:' || location.protocol === 'https:')
      return location.protocol + '//' + location.hostname + ':8787';
    return 'http://localhost:8787';
  })();
  function api(path, payload, timeoutMs) {
    var ctl = ('AbortController' in window) ? new AbortController() : null;
    var timer = ctl && setTimeout(function () { ctl.abort(); }, timeoutMs || 12000);
    return fetch(API_BASE + path, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(payload),
      signal: ctl ? ctl.signal : undefined
    }).then(function (r) {
      if (timer) clearTimeout(timer);
      if (!r.ok) throw new Error('http ' + r.status);
      return r.json();
    }, function (e) { if (timer) clearTimeout(timer); throw e; });
  }
  /* the no-dashes rule is enforced in the AI system prompt AND here as a backstop */
  function clean(s) { return String(s || '').replace(/\s*[—–]\s*/g, ', '); }

  var vehicle = CarBox.get('vehicle');
  var goal = CarBox.get('goal');
  var budget = CarBox.get('budget');
  document.querySelector('.goalpill span').textContent = 'Goal: ' + goal;
  document.querySelector('.upghead .sub').textContent = 'for your ' + vehicle.name;
  /* "Change goal" is the ONLY way into the goal picker (the pill is a label) */
  document.querySelector('.changegoal').addEventListener('click', function () {
    location.href = 'goal-picker.html';
  });
  /* budget label under the goal row; tapping jumps to the goal flow to change it */
  function budgetText(b) {
    if (!b) return '';
    if (b.max == null) return CarBox.fmtMoney(b.min) + '+';
    if (b.min > 0) return CarBox.fmtMoney(b.min) + '–' + CarBox.fmtMoney(b.max);
    return 'Under ' + CarBox.fmtMoney(b.max);
  }
  var budgetLine = $('budgetline');
  if (budget) { budgetLine.textContent = 'Budget: ' + budgetText(budget); budgetLine.style.display = ''; }
  else { budgetLine.style.display = 'none'; }
  budgetLine.addEventListener('click', function () { location.href = 'goal-picker.html'; });

  /* ════════ AI RECOMMENDATIONS (Part B) ════════ */
  var recsWrap = $('recs');
  var recNote = $('recnote');
  function renderNote(note) {
    if (note) { recNote.textContent = note; recNote.style.display = ''; }
    else { recNote.textContent = ''; recNote.style.display = 'none'; }
  }
  var budgetKey = budget ? budget.min + '-' + budget.max : 'nb';
  var recsKey = [vehicle.make, vehicle.model, vehicle.year, vehicle.trim || '', goal, budgetKey].join('|');
  var items = [];   /* [{name, benefit, detail}] */

  function card(html) {
    var stage = document.createElement('div');
    stage.className = 'stage';
    stage.innerHTML = '<span class="dot"></span>' + html;
    return stage;
  }
  function renderSkeleton() {
    recsWrap.querySelectorAll('.stage').forEach(function (el) { el.remove(); });
    for (var i = 0; i < 2; i++) {
      recsWrap.appendChild(card(
        '<div class="scard skel" aria-hidden="true">' +
        '<div class="skelline w40"></div><div class="skelline w70"></div><div class="skelline w55"></div></div>'
      ));
    }
  }

  var CHECK_SVG = '<svg viewBox="0 0 24 24" width="12" height="12" aria-hidden="true" ' +
    'style="display:inline-block;vertical-align:-1px"><path d="M4 12.5 L10 18.5 L20 6.5" fill="none" ' +
    'stroke="currentColor" stroke-width="3.4" stroke-linecap="round" stroke-linejoin="round"/></svg>';

  function mappedName() {
    var m = CarBox.get('mappedMod');
    for (var i = 0; i < items.length; i++) if (items[i].name === m) return m;
    return items.length ? items[0].name : null;
  }
  function paintMapped() {
    var m = mappedName();
    recsWrap.querySelectorAll('.scard').forEach(function (el) {
      var isOn = el.getAttribute('data-name') === m;
      el.classList.toggle('mapped', isOn);
      var btn = el.querySelector('.addmap');
      if (btn) {
        btn.classList.toggle('onmap', isOn);
        btn.innerHTML = isOn ? 'On map ' + CHECK_SVG : 'Add to map';
      }
    });
  }

  function openDetail(mod) {
    UI.sheet({
      title: mod.name,
      label: mod.name,
      build: function (body) {
        var meta = document.createElement('div');
        meta.className = 'sheetrow';
        meta.innerHTML = '<div class="rowtop">Estimated</div>';
        var mtx = document.createElement('div');
        mtx.className = 'rowtx';
        mtx.textContent = clean(mod.benefit);
        meta.appendChild(mtx);
        body.appendChild(meta);
        var row = document.createElement('div');
        row.className = 'sheetrow';
        var tx = document.createElement('div');
        tx.className = 'rowtx';
        tx.textContent = clean(mod.detail);   /* paragraph: what it is, what it does, why this car */
        row.appendChild(tx);
        body.appendChild(row);
      }
    });
  }

  function renderRecs() {
    recsWrap.querySelectorAll('.stage').forEach(function (el) { el.remove(); });
    items.forEach(function (mod) {
      var stage = card(
        '<div class="scard" data-name="' + mod.name.replace(/"/g, '&quot;') + '" role="button" tabindex="0" data-press>' +
        '<span class="schip">RECOMMENDED</span>' +
        '<div class="stitle"></div>' +
        '<div class="smeta"></div>' +
        '<button class="addmap">Add to map</button></div>'
      );
      stage.querySelector('.stitle').textContent = mod.name;
      stage.querySelector('.smeta').textContent = clean(mod.benefit);
      var sc = stage.querySelector('.scard');
      sc.addEventListener('click', function (e) {
        if (e.target.closest('.addmap')) return;
        openDetail(mod);
      });
      sc.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') openDetail(mod);
      });
      stage.querySelector('.addmap').addEventListener('click', function () {
        CarBox.set('mappedMod', mod.name);
        var b = this;
        b.classList.remove('pop'); void b.offsetWidth; b.classList.add('pop');
        paintMapped();
        loadShops();   /* swap the map section to this mod's shops */
      });
      recsWrap.appendChild(stage);
    });
    if (!CarBox.get('mappedMod') || mappedName() !== CarBox.get('mappedMod')) {
      CarBox.set('mappedMod', mappedName());
    }
    paintMapped();
  }

  /* ── LOCAL FALLBACK recommender (budget-aware) ──
     Used when the API proxy is unreachable/keyless, so the page never breaks.
     Rules-based pools per goal + aspiration, each with an approx installed cost;
     filtered by the budget cap so it never suggests something unaffordable.
     Detail strings contain no em/en dashes. Returns { items, note }. */
  function selectByBudget(pool, cap) {
    var sorted = pool.slice().sort(function (a, b) { return a.cost - b.cost; });
    var affordable = (cap == null) ? sorted : sorted.filter(function (m) { return m.cost <= cap; });
    var chosen, note = null;
    if (affordable.length >= 2) chosen = affordable.slice(0, 2);
    else if (affordable.length === 1) { chosen = affordable.slice(0, 1); note = 'Only one solid mod fits this budget. Raise it a little for a second option.'; }
    else { chosen = sorted.slice(0, 1); note = 'The mods for this goal sit above your budget right now, so here is the most affordable place to start.'; }
    return { items: chosen.map(function (m) { return { name: m.name, benefit: m.benefit, detail: m.detail }; }), note: note };
  }
  function localRecs(cap) {
    var s = vehicle.specs || {};
    var eng = String(s.engine || '').toLowerCase();
    var ev = /electric/.test(eng);
    var boosted = /turbo|supercharg/.test(eng);
    var t = vehicle.year + ' ' + vehicle.make + ' ' + vehicle.model;
    function R(name, benefit, detail, cost) { return { name: name, benefit: benefit, detail: detail, cost: cost }; }
    var pool;
    if (goal === 'Better handling') {
      pool = [
        R('Sway bar upgrade', 'Less body roll for little money, roughly $250-450', 'A stiffer front and rear anti-roll bar set ties the wheels together so the ' + t + ' leans less and turns in flatter. It is a cheap, reversible bolt-on that sharpens handling without hurting ride quality, which makes it a great first step on any budget.', 350),
        R('Performance summer tires', 'The biggest grip per dollar, roughly $600-1,100 a set', 'Tires are the only contact with the road, so modern performance summer tires transform grip, braking, and steering feel at once on the ' + t + '. They are safe, reversible, and work with every stock part, which is why they come before anything else.', 850),
        R('Coilover suspension kit', 'Adjustable height and damping, roughly $1,200-2,200', 'A coilover kit replaces the springs and shocks with height and damping adjustable units, lowering the center of gravity and cutting body roll on the ' + t + '. You can fine tune how firm it feels, keeping comfort at softer settings. It is the biggest single handling step.', 1700)
      ];
    } else if (goal === 'Show car looks') {
      pool = [
        R('Window tint', 'Clean look, cooler cabin, roughly $250-450', 'A quality tint gives the ' + t + ' a finished, aggressive look while blocking heat and UV, and it is done in a couple of hours. One of the most affordable cosmetic upgrades and a simple, high impact place to start.', 350),
        R('Paint correction and ceramic coating', 'Deep lasting gloss, roughly $600-1,200', 'Paint correction polishes out swirls and haze, then a ceramic coating seals that finish so the ' + t + ' beads water and stays glossy for years. Flawless paint is the base layer every other cosmetic mod sits on.', 900),
        R('Aftermarket wheel setup', 'A complete stance change, roughly $1,400-2,600', 'A well chosen set of wheels in the right width and offset changes the whole character of the ' + t + ' more than any other visual mod, and it stays bolt-on and reversible. The highest impact way to make it look intentional.', 2000)
      ];
    } else if (goal === 'Track ready') {
      pool = [
        R('Track brake pads and fluid', 'Fade-free stops all session, roughly $400-800', 'High temperature pads and racing fluid keep the pedal firm lap after lap where stock parts fade. On the ' + t + ' this is the first safety critical track upgrade, worth more lap time than power because it lets you brake later with confidence.', 600),
        R('200TW track tires', 'Seconds off your lap time, roughly $800-1,400 a set', 'A 200 treadwear tire is street legal but built for circuit grip, with stiff sidewalls and a compound that wakes up with heat. On the ' + t + ' grip from the tires makes the brakes, power, and suspension all work better together.', 1100),
        R('Coilover suspension kit', 'Flatter, predictable handling, roughly $1,200-2,200', 'Track focused coilovers lower the ' + t + ' and let you dial in damping and corner balance so it stays flat and predictable at the limit. Pair them with good tires and brakes for a complete track setup.', 1700)
      ];
    } else if (ev) {
      pool = [
        R('Lowering springs', 'Better stance and response, roughly $300-600', 'A quality lowering spring set drops the ' + t + ' slightly, lowering the center of gravity for sharper turn in and a planted look while keeping the stock dampers. An affordable way to make an EV feel more connected.', 500),
        R('High-grip summer tires', 'Puts the instant torque down, roughly $700-1,200 a set', 'EVs often overpower their efficiency tires. A performance summer tire converts the ' + t + ' instant torque into real acceleration instead of wheelspin and shortens braking too. The safest, most effective way to use the power it already has.', 950),
        R('Lightweight wheels', 'Quicker feel and sharper handling, roughly $1,200-2,000', 'Shedding rotating mass with lighter wheels makes the ' + t + ' accelerate and change direction more eagerly, and it can even help range a little. It keeps the powertrain and warranty untouched.', 1600)
      ];
    } else if (boosted) {
      pool = [
        R('ECU flash tune', 'Best power per dollar, roughly $500-900', 'A flash tune rewrites the factory calibration to raise boost and optimize fuel and timing within safe limits. Because the ' + t + ' already runs forced induction, the headroom is there and a reputable dyno tune unlocks real gains. The single best value power mod here.', 700),
        R('Intercooler upgrade', 'Consistent power, less heat soak, roughly $700-1,200', 'A larger intercooler keeps intake temperatures down so the ' + t + ' holds power on repeated pulls and hot days instead of pulling timing. A reliable supporting mod that pairs perfectly with a tune.', 950),
        R('Cat-back exhaust system', 'Freer flow and real sound, roughly $800-1,500', 'A cat-back replaces the restrictive rear piping with larger, smoother tubing, freeing a little power, cutting weight, and giving the ' + t + ' a genuine voice. It helps the whole system breathe alongside a tune.', 1150)
      ];
    } else {
      pool = [
        R('Cold air intake', 'Better breathing and response, roughly $300-450', 'A cold air intake swaps the airbox for a freer flowing filter drawing cooler, denser air. On the naturally aspirated ' + t + ' the gains are modest but throttle response and sound improve right away. Affordable, reversible, and safe with the stock computer.', 380),
        R('Cat-back exhaust system', 'Flow, sound, and less weight, roughly $700-1,400', 'A cat-back swaps the muffler and rear piping for a straighter, larger path, freeing a few horsepower and cutting weight while giving the ' + t + ' a cleaner note without drone. A sensible naturally aspirated power step.', 1050),
        R('Long-tube headers', 'The biggest N/A gain, roughly $1,000-1,800', 'Long tube headers improve exhaust scavenging for the ' + t + ' and, with a supporting tune, give the largest naturally aspirated power gain of these options. Best combined with the intake and exhaust as a package.', 1400)
      ];
    }
    return selectByBudget(pool, cap);
  }

  function initRecs() {
    var cap = budget ? budget.max : null;
    var cached = CarBox.get('recs');
    if (cached && cached.key === recsKey && cached.source === 'api' && cached.items && cached.items.length >= 1) {
      items = cached.items;      /* fresh cache for this exact car+goal+budget */
      renderNote(null); renderRecs();
      return;
    }
    if (cached && cached.key === recsKey && cached.items && cached.items.length >= 1) {
      items = cached.items;      /* fallback cache: show instantly, still retry the API */
      renderNote(cached.note || null); renderRecs();
    } else {
      renderSkeleton();
    }
    api('/api/recommend', {
      make: vehicle.make, model: vehicle.model, year: vehicle.year,
      trim: vehicle.trim || '', specs: vehicle.specs || {}, goal: goal, budget: budget
    }, 20000).then(function (data) {
      if (data && data.recommendations && data.recommendations.length === 2) {
        items = data.recommendations.map(function (m) {
          return { name: m.name, benefit: clean(m.benefit), detail: clean(m.detail) };
        });
        CarBox.set('recs', { key: recsKey, items: items, source: 'api' });
        renderNote(null); renderRecs(); loadShops();
      } else { throw new Error('bad payload'); }
    }).catch(function () {
      /* FALLBACK: proxy down or key missing — never show a broken state.
         Respects the budget cap so it never suggests something unaffordable. */
      if (!items.length) {
        var res = localRecs(cap);
        items = res.items;
        CarBox.set('recs', { key: recsKey, items: items, source: 'local', note: res.note });
        renderNote(res.note); renderRecs(); loadShops();
      }
    });
  }

  /* ════════ WHERE TO GET IT DONE (Parts C + D) ════════ */
  var mapzone = $('mapzone'), mapsub = $('mapsub');
  var shops = [];

  function fmtDist(mi) {
    return CarBox.get('units') === 'km'
      ? (mi * 1.60934).toFixed(1) + ' km'
      : mi + ' mi';
  }
  function shopMeta(s) {
    return s.rating + ' ★ (' + (s.ratingCount || 0) + ') · ' + fmtDist(s.distanceMiles) + ' · ' + s.priceEstimate;
  }
  /* real directions: deep link into the maps app (Google Maps universal URL) */
  function openDirections(s) {
    var url = s.mapsUrl || ('https://www.google.com/maps/search/?api=1&query=' + encodeURIComponent(s.name));
    var w = null;
    try { w = window.open(url, '_blank'); } catch (e) {}
    if (!w) location.href = url;
  }

  function setSub(txt) { mapsub.textContent = txt; }
  function zone(html) { mapzone.innerHTML = html; }

  function renderLocked() {
    var m = mappedName();
    setSub(m ? m : 'Nearby shops');
    zone('<div class="maplock">' +
      '<img src="assets/badge_lock.png" alt="">' +
      '<div class="lktx">Allow location access to see real shops near you that can do this mod, with live ratings, distances, and price estimates.</div>' +
      '<button class="lkbtn" id="lockAllow">Allow location</button></div>');
    $('lockAllow').addEventListener('click', function () {
      if (!navigator.geolocation) { UI.toast('Location isn’t available on this device'); return; }
      var b = this; b.disabled = true; b.textContent = 'Requesting…';
      navigator.geolocation.getCurrentPosition(function (pos) {
        CarBox.set('locationGranted', true);
        CarBox.set('location', { lat: pos.coords.latitude, lng: pos.coords.longitude });
        loadShops();
      }, function () {
        b.disabled = false; b.textContent = 'Allow location';
        UI.toast('Location was denied — check your device settings');
      }, { enableHighAccuracy: false, timeout: 12000, maximumAge: 300000 });
    });
  }

  function renderLoading() {
    var m = mappedName();
    setSub(m ? m + ' · finding shops near you…' : 'Finding shops…');
    zone('<div class="mapwrap"><img class="mapimg" src="assets/map_shops.png" alt="Map of nearby shops"></div>' +
      '<div class="shopskel"><div class="skelline w70"></div><div class="skelline w55"></div>' +
      '<div class="skelline w70"></div><div class="skelline w40"></div></div>');
  }

  function renderError() {
    var m = mappedName();
    setSub(m || 'Nearby shops');
    zone('<div class="mapmsg">Couldn’t reach the shop service. Check that the CarBox API proxy is running, then try again.' +
      '<button class="retry" id="shopRetry">Try again</button></div>');
    $('shopRetry').addEventListener('click', loadShops);
  }

  function renderEmpty() {
    var m = mappedName();
    setSub(m || 'Nearby shops');
    zone('<div class="mapmsg">No shops for this mod found near you yet. Try again later or widen your search from a bigger city.</div>');
  }

  function renderShops() {
    var m = mappedName();
    setSub(m + ' · ' + shops.length + ' shop' + (shops.length === 1 ? '' : 's') + ' near you');
    var html = '<div class="mapwrap"><img class="mapimg" src="assets/map_shops.png" alt="Map of nearby shops">' +
      '<span class="pinpulse" style="left:47%;top:42%" aria-hidden="true"></span></div>';
    zone(html);
    var first = shops[0];
    var row = document.createElement('div');
    row.className = 'shoprow';
    row.innerHTML = '<div><div class="sname"></div><div class="srate"></div></div>' +
      '<button class="directions">Directions</button>';
    row.querySelector('.sname').textContent = first.name;
    row.querySelector('.srate').textContent = shopMeta(first);
    row.querySelector('.directions').addEventListener('click', function () { openDirections(first); });
    mapzone.appendChild(row);
    if (shops.length > 1) {
      var btn = document.createElement('button');
      btn.className = 'seeall';
      btn.textContent = 'See all ' + shops.length + ' shops';
      btn.addEventListener('click', seeAllSheet);
      mapzone.appendChild(btn);
    }
    var pin = mapzone.querySelector('.pinpulse');
    if (pin && !UI.reduced()) pin.classList.add('pindrop');
  }

  function seeAllSheet() {
    UI.sheet({
      title: 'Shops near you',
      label: 'Shops near you',
      build: function (body) {
        shops.forEach(function (s) {
          var row = document.createElement('div');
          row.className = 'sheetrow rowflex';
          var left = document.createElement('div');
          var nm = document.createElement('div'); nm.className = 'rowtop'; nm.textContent = s.name;
          var mt = document.createElement('div'); mt.className = 'rowtx'; mt.textContent = shopMeta(s);
          left.appendChild(nm); left.appendChild(mt);
          var btn = document.createElement('button');
          btn.className = 'directions';
          btn.textContent = 'Directions';
          btn.setAttribute('aria-label', 'Directions to ' + s.name);
          btn.addEventListener('click', function () { openDirections(s); });
          row.appendChild(left); row.appendChild(btn);
          body.appendChild(row);
        });
        var note = document.createElement('div');
        note.className = 'sheet-note';
        note.textContent = 'Ratings live from Google · prices are estimates';
        body.appendChild(note);
      }
    });
  }

  /* live call every time — ratings/distances must be current, so no caching */
  function loadShops() {
    var m = mappedName();
    if (!m) { setSub(''); zone(''); return; }
    if (!CarBox.get('locationGranted') || !CarBox.get('location')) { renderLocked(); return; }
    renderLoading();
    var loc = CarBox.get('location');
    api('/api/shops', { lat: loc.lat, lng: loc.lng, modName: m }, 15000)
      .then(function (data) {
        shops = (data && data.shops) || [];
        if (!shops.length) renderEmpty(); else renderShops();
      })
      .catch(renderError);
  }

  /* ── boot ── */
  initRecs();
  loadShops();
  UI.condense('Upgrades');
});
</script>
</body>
</html>
