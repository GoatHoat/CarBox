<style>

  .upghead{display:block}
  .upghead h1{font-size:38px;color:var(--tx,#141210);line-height:1}
  .upghead .sub{font-size:15px;font-weight:500;color:var(--warmgray);margin-top:2px}

  .goalrow{display:flex;gap:9px;margin-top:10px}
  /* goal label — NOT a button: plain chip, no press/hover, no chevron */
  .goalpill{
    display:flex;align-items:center;
    background:var(--accent,#796457);border-radius:999px;
    padding:8px 15px;box-shadow:var(--shadow);cursor:default;
  }
  .goalpill span{color:#FBF8F4;font-weight:600;font-size:14.5px;white-space:nowrap}
  .changegoal{
    background:transparent;border:2.5px solid #C2B6AA;border-radius:999px;cursor:pointer;
    padding:7px 16px;color:var(--mut,#8D8579);font-family:'League Spartan',sans-serif;font-weight:600;font-size:14.5px;
  }

  .budgetline{font-size:13.5px;font-weight:600;color:var(--warmgray);margin-top:8px;cursor:pointer}
  .recnote{
    font-size:13px;font-weight:600;color:var(--mut,#8D8D8B);line-height:1.4;
    margin-top:10px;display:none;
  }
  .stages{position:relative;margin-top:10px}
  .stages .rail{
    position:absolute;right:9px;top:30px;bottom:30px;width:3px;
    background:#6E5B4B;border-radius:2px;
  }
  .stage{position:relative;margin-right:26px;margin-bottom:8px}
  .stage .dot{
    position:absolute;right:-20px;top:50%;transform:translateY(-50%);
    width:9px;height:9px;border-radius:50%;background:#6E5B4B;
  }
  .scard{
    background:var(--surface,#F5F3F4);border-radius:16px;box-shadow:var(--shadow);
    padding:10px 13px;position:relative;cursor:pointer;
  }
  .scard.mapped{box-shadow:var(--shadow),inset 0 0 0 2.5px #6E5A46}
  .schip{
    display:inline-block;border-radius:999px;padding:3px 11px;
    background:var(--accent,#7B6558);color:#FBF8F4;
    font-size:10.5px;font-weight:600;letter-spacing:.05em;
  }
  .scard .stitle{font-size:17px;font-weight:600;color:var(--tx,#17130F);margin-top:5px;line-height:1.1;padding-right:70px}
  .scard .smeta{font-size:13.5px;font-weight:600;color:var(--meta);margin-top:2px;padding-right:70px}
  .addmap{
    position:absolute;right:13px;bottom:11px;
    background:none;border:none;cursor:pointer;
    color:var(--accent-tx,#776357);font-family:'League Spartan',sans-serif;font-weight:600;font-size:13.5px;
    min-height:24px;
  }
  .addmap.onmap{color:var(--brown-warm)}

  /* loading skeleton — same card bones, gently pulsing */
  .skelline{height:12px;border-radius:6px;background:var(--ctl,#E3DED9);margin-top:8px}
  .skelline.w40{width:40%}.skelline.w70{width:70%}.skelline.w55{width:55%}
  .scard.skel{cursor:default;min-height:64px}
  @keyframes skelpulse{0%,100%{opacity:.55}50%{opacity:1}}
  .skelline{animation:skelpulse 1.3s ease-in-out infinite}

  .mapcard{
    background:var(--surface,#F5F3F4);border-radius:18px;box-shadow:var(--shadow);
    margin-top:10px;padding:12px 12px 11px;
  }
  .mapcard h2{font-size:17px;font-weight:600;color:var(--tx,#17130F);font-family:'League Spartan',sans-serif}
  .mapcard .msub{font-size:13px;font-weight:500;color:var(--warmgray);margin-top:1px}
  .mapimg{width:100%;border-radius:12px;margin-top:8px}
  .shoprow{display:flex;align-items:center;justify-content:space-between;margin-top:9px;gap:8px}
  .shoprow .sname{font-size:15.5px;font-weight:600;color:var(--tx,#17130F);line-height:1.15}
  .shoprow .srate{font-size:12.5px;font-weight:600;color:var(--meta);margin-top:1px}
  .directions{
    background:transparent;border:2.5px solid #A79A8C;border-radius:999px;cursor:pointer;
    padding:6px 13px;color:var(--accent-tx,#776357);font-family:'League Spartan',sans-serif;font-weight:600;font-size:13.5px;
    flex:none;
  }
  .seeall{
    width:100%;margin-top:10px;
    background:var(--accent,#786557);color:#FBF8F4;border:none;border-radius:999px;cursor:pointer;
    padding:9px 0;font-family:'League Spartan',sans-serif;font-weight:600;font-size:14.5px;
    box-shadow:var(--shadow);
  }

  /* location-locked map state: opaque brown block, lock, explanation */
  .maplock{
    background:var(--brown-warm);border-radius:12px;margin-top:8px;
    min-height:170px;display:flex;flex-direction:column;align-items:center;justify-content:center;
    gap:8px;padding:18px 22px;text-align:center;
  }
  .maplock img{width:34px}
  .maplock .lktx{color:#FBF8F4;font-size:14px;font-weight:600;line-height:1.35}
  .maplock .lkbtn{
    margin-top:4px;background:#FBF8F4;color:var(--brown-warm);border:none;border-radius:999px;cursor:pointer;
    padding:9px 20px;font-family:'League Spartan',sans-serif;font-weight:700;font-size:14px;
  }

  /* error / empty message inside the map card */
  .mapmsg{
    margin-top:10px;padding:14px 6px 6px;text-align:center;
    font-size:13.5px;font-weight:600;color:var(--mut,#8D8D8B);line-height:1.4;
  }
  .mapmsg .retry{
    display:block;margin:10px auto 4px;
    background:transparent;border:2.5px solid #A79A8C;border-radius:999px;cursor:pointer;
    padding:6px 16px;color:var(--accent-tx,#776357);font-family:'League Spartan',sans-serif;font-weight:600;font-size:13.5px;
  }
  .shopskel{margin-top:12px}

  @media (prefers-reduced-motion: reduce){
    .skelline{animation:none;opacity:.7}
  }
</style>
