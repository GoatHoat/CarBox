  <!-- AI recommendations render here (skeleton first, then 2 cards) -->
  <div class="stages" id="recs">
    <div class="rail"></div>
  </div>

  <div class="mapcard">
    <h2>Where to get it done</h2>
    <div class="msub" id="mapsub"></div>
